# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL (Neon, Supabase, Railway, dll)
# Contoh Neon:     postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
# Contoh Supabase: postgresql://postgres:[pass]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Cloudinary (Upload Foto) ─────────────────────────────────────────────────
# Daftar gratis di https://cloudinary.com
# Cloud name ada di dashboard Cloudinary (format: dxxxxxxxx)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
